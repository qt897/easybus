# Base URL of the GitHub-hosted transit data source (server-side only,
# used by app/api/routes/*). No trailing slash.
EASYBUS_DATA_BASE_URL=https://raw.githubusercontent.com/qt897/easybus/refs/heads/main/data

# How long (seconds) upstream data fetches are cached for.
EASYBUS_DATA_CACHE_SECONDS=3600

# MapLibre style URLs (client-side, must be reachable from the browser).
NEXT_PUBLIC_MAP_STYLE_SIMPLE_URL=https://tiles.openfreemap.org/styles/positron
NEXT_PUBLIC_MAP_STYLE_DETAILED_URL=https://tiles.openfreemap.org/styles/liberty

# Default map center + zoom (Ho Chi Minh City).
NEXT_PUBLIC_CITY_CENTER_LAT=10.7769
NEXT_PUBLIC_CITY_CENTER_LNG=106.6997
NEXT_PUBLIC_DEFAULT_MAP_ZOOM=12.2
